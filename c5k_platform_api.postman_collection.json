{
    "info": {
        "_postman_id": "c5k-platform-api",
        "name": "C5K Platform API",
        "description": "Complete API collection for C5K Platform with automatic JWT handling.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{token}}",
                "type": "string"
            }
        ]
    },
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    "// This runs before every request in the collection"
                ]
            }
        },
        {
            "listen": "test",
            "script": {
                "type": "text/javascript",
                "exec": [
                    "// Global test scripts"
                ]
            }
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.success && jsonData.data && jsonData.data.accessToken) {",
                                    "    pm.collectionVariables.set(\"token\", jsonData.data.accessToken);",
                                    "    console.log(\"Token stored automatically: \" + jsonData.data.accessToken);",
                                    "    pm.toast(\"Login Successful - Token Saved\");",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"newuser@example.com\",\n    \"password\": \"password123\",\n    \"university\": \"Test Uni\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Current User (Me)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "me"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Articles",
            "item": [
                {
                    "name": "Submit Article",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"My New Research\",\n    \"abstract\": \"This is a test abstract.\",\n    \"journalId\": \"some-uuid\",\n    \"fileUrl\": \"https://example.com/file.pdf\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/articles/submit",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "articles",
                                "submit"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Public Articles",
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/articles/public",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "articles",
                                "public"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Books & Wishlist",
            "item": [
                {
                    "name": "Add/Remove Wishlist",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"action\": \"wishlist\",\n    \"bookId\": \"BOOK_UUID_HERE\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/books/interact",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "books",
                                "interact"
                            ]
                        }
                    }
                },
                {
                    "name": "Purchase Book",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"action\": \"purchase\",\n    \"bookId\": \"BOOK_UUID_HERE\",\n    \"price\": \"$50\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/books/interact",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "books",
                                "interact"
                            ]
                        }
                    }
                },
                {
                    "name": "Get My Wishlist",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/dashboard/wishlist",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "dashboard",
                                "wishlist"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Admin / Editor",
            "item": [
                {
                    "name": "Get Analytics",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/analytics",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "analytics"
                            ]
                        }
                    }
                },
                {
                    "name": "Manage Users",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/editor/users",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "editor",
                                "users"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}