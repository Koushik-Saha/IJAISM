# =============================================================================
# IJAISM environment variables — copy to .env (gitignored) and fill in.
# In production (Oracle Cloud VM) this lives at /opt/ijaism/.env and is read by
# docker-compose. In local dev, place it at the repo root.
# =============================================================================

# ---- Application ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="IJAISM"
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"

# ---- Secrets (generate with: openssl rand -base64 32) ----
JWT_SECRET="change-me"
JWT_EXPIRES_IN="1h"
NEXTAUTH_SECRET="change-me"

# ---- Database ----
# Local dev (docker-compose.dev.yml exposes 5432):
DATABASE_URL="postgresql://ijaism:ijaism@localhost:5432/ijaism?schema=public"
# On the production VM, docker-compose composes this automatically from
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB below.
POSTGRES_USER="ijaism"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="ijaism"

# ---- Object storage (Cloudflare R2; S3-compatible) ----
# Get from Cloudflare dashboard → R2 → Manage R2 API Tokens. We use the AWS_*
# naming because lib/s3.ts uses the AWS SDK, which natively reads these.
AWS_S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="auto"
AWS_S3_BUCKET_NAME="ijaism-uploads"

# ---- Email (Resend recommended) ----
RESEND_API_KEY=""
EMAIL_FROM="IJAISM <noreply@ijaism.org>"
EMAIL_REPLY_TO="support@ijaism.org"
# Alternative: SMTP (used only if RESEND_API_KEY is unset)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM_NAME="IJAISM Platform"
# SMTP_FROM_EMAIL="noreply@ijaism.com"

# ---- Stripe ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_PREMIUM=""
STRIPE_PRICE_INSTITUTIONAL=""

# ---- PayPal ----
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# ---- Sentry (optional; runtime DSN + build-time auth token) ----
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN is build-only — pass via GitHub Actions secret, not here.

# ---- Caddy (production VM only) ----
DOMAIN="ijaism.com"
ACME_EMAIL="admin@ijaism.org"
CLOUDFLARE_API_TOKEN=""

# ---- Container image (production VM only) ----
APP_IMAGE="ghcr.io/koushik-saha/ijaism:latest"
